# ══════════════════════════════════════════════════════════════════════════════
# Vayu Research — Environment Configuration
# Copy this file to .env and fill in your values.
# All variables are optional unless marked REQUIRED.
# ══════════════════════════════════════════════════════════════════════════════


# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which provider to use: anthropic | openai | openrouter
# openrouter is recommended — single key, access to every model
DEFAULT_PROVIDER=openrouter

# Model name for the chosen provider.
# Anthropic:   claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# OpenAI:      gpt-4o | gpt-4o-mini | o1 | o3-mini
# OpenRouter:  provider/model — browse full list at https://openrouter.ai/models
#   Paid:  anthropic/claude-opus-4-6 | openai/gpt-4o | google/gemini-2.5-pro
#          meta-llama/llama-4-maverick | deepseek/deepseek-r1 | x-ai/grok-3
#   Free:  append :free to any model that supports it, e.g.
#          meta-llama/llama-4-maverick:free | deepseek/deepseek-r1:free
#          google/gemini-2.5-pro:free | mistralai/mistral-7b-instruct:free
DEFAULT_MODEL=anthropic/claude-opus-4-6

# Maximum tokens the model may generate per response (default: 4096)
# Increase for very long research outputs; decrease to save cost
LLM_MAX_TOKENS=4096


# ── API Keys ──────────────────────────────────────────────────────────────────
# Only the key for your chosen DEFAULT_PROVIDER is required.

# REQUIRED if DEFAULT_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...

# REQUIRED if DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED if DEFAULT_PROVIDER=openai
OPENAI_API_KEY=sk-...


# ── OpenRouter extras ─────────────────────────────────────────────────────────
# Optional — improves rate-limit tier and appears in OpenRouter analytics
OPENROUTER_SITE_URL=https://your-deployed-app.up.railway.app
OPENROUTER_APP_NAME=Vayu Research


# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero-config) or Supabase/Postgres for production
# SQLite:          sqlite:///./vayu.db
# Supabase direct: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Supabase pooler: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Note: copy the connection string from Supabase dashboard → Settings → Database → Connection string
DATABASE_URL=sqlite:///./vayu.db


# ── Scheduler ─────────────────────────────────────────────────────────────────
# Timezone for scheduled runs — use IANA tz names
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
SCHEDULER_TIMEZONE=Asia/Kolkata


# ── Notion Integration ────────────────────────────────────────────────────────
# Required for saving results to Notion (optional feature)
NOTION_TOKEN=secret_...
# Parent page under which each result is saved as a new child page.
# Each result gets its own page with title, metadata callout, and formatted content.
# Also configurable in the Settings UI as a fallback.
NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Notion API version — only change if Notion releases a breaking update
NOTION_API_VERSION=2022-06-28
# Timeout in seconds for Notion API calls (default: 15)
NOTION_TIMEOUT=15


# ── Email Delivery ────────────────────────────────────────────────────────────
# Required for email notifications on scheduled runs
GMAIL_ADDRESS=you@gmail.com
# Generate at: myaccount.google.com → Security → App Passwords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Where to send results — defaults to GMAIL_ADDRESS if not set
EMAIL_TO=you@gmail.com
# SMTP server — change only if using a provider other than Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465


# ── Telegram Delivery ─────────────────────────────────────────────────────────
# Required for Telegram notifications on scheduled runs
# Create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:AAH...
TELEGRAM_CHAT_ID=123456789
