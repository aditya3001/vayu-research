# ── LLM Provider ──────────────────────────────────────────────────────────────
DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=
LIVE_MODE=live
DEFAULT_LIVE_MODEL=perplexity/sonar-pro
DEFAULT_DEMO_MODEL=openrouter/free
LLM_MAX_TOKENS=6000


# ── API Keys ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=


# ── OpenRouter extras ─────────────────────────────────────────────────────────
OPENROUTER_SITE_URL=https://your-deployed-app.up.railway.app
OPENROUTER_APP_NAME=Vayu Research


# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./vayu.db


# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Asia/Kolkata


# ── Notion Integration ────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_PAGE_ID=
NOTION_API_VERSION=2022-06-28
NOTION_TIMEOUT=30


# ── Email Delivery ────────────────────────────────────────────────────────────
# GMAIL_ADDRESS=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# EMAIL_TO=you@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465


# ── Telegram Delivery ─────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=1234567890:AAH...
# TELEGRAM_CHAT_ID=123456789


# ── Auth (JWT + OAuth) ────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-me-with-a-secure-random-string

# Backend base URL used to build OAuth callback URLs
# Dev: http://localhost:8000  |  Prod: https://yourdomain.com
BACKEND_URL=http://localhost:8000

# Frontend URL for OAuth post-callback redirect
# Dev: http://localhost:5173  |  Prod: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# OAuth providers (optional — only needed if GitHub/Google login is used)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to "true" in production (requires HTTPS). "false" for local HTTP dev.
COOKIE_SECURE=false
